#include <iostream>
#include <vector>
using namespace std;

vector<int> graph[100];
bool visited[100];

void dfs(int node)
{
    visited[node] = true;

    cout<<node<<" ";

    for(int x : graph[node])
    {
        if(!visited[x])
            dfs(x);
    }
}

int main()
{
    int n,e;

    cout<<"Enter vertices and edges: ";
    cin>>n>>e;

    cout<<"Enter edges:\n";

    for(int i=0;i<e;i++)
    {
        int u,v;
        cin>>u>>v;

        graph[u].push_back(v);
        graph[v].push_back(u);
    }

    cout<<"DFS Traversal:\n";

    dfs(0);

    return 0;
}
